{
  "title": "Lucky Ducks",
  "description": "On-chain duck racing on Solana. Player documentation.",
  "author": "The Lucky Ducks team",
  "language": "en",
  "gitbook": ">=3.0.0",
  "plugins": [
    "-search",
    "search-plus",
    "expandable-chapters-small",
    "anchor-navigation-ex",
    "page-toc-button",
    "copy-code-button"
  ],
  "pluginsConfig": {
    "anchor-navigation-ex": {
      "showLevel": true,
      "associatedWithSummary": true,
      "printLog": false,
      "multipleH1": false,
      "mode": "float",
      "showGoTop": true,
      "float": {
        "floatIcon": "fa fa-list",
        "showLevelIcon": false,
        "level1Icon": "fa fa-hand-o-right",
        "level2Icon": "fa fa-hand-o-right",
        "level3Icon": "fa fa-hand-o-right"
      }
    },
    "page-toc-button": {
      "maxTocDepth": 3,
      "minTocSize": 2
    }
  },
  "styles": {
    "website": "styles/website.css"
  },
  "variables": {
    "brand": {
      "name": "Lucky Ducks",
      "primary": "#ffd700",
      "accent": "#11d4c4"
    }
  }
}
